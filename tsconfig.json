{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["lib/**/*.ts", "types/**/*.ts", "src/_data/**/*.ts"],
  "exclude": ["node_modules", "_site"]
}
