---
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title } = Astro.props;
const pageTitle = title ? `${title} | hashiiiii` : 'hashiiiii';
---

<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>
  <script is:inline src="https://embed.zenn.studio/js/listen-embed-event.js"></script>
</head>
<body>
  <Header currentPath={Astro.url.pathname} />
  <main>
    <slot />
  </main>
  <footer>
    <p>&copy; 2025 hashiiiii. All rights reserved.</p>
  </footer>
</body>
</html>

<style>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1rem;
    width: 100%;
    flex: 1;
  }

  footer {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    font-family: var(--font-mono);
  }
</style>
