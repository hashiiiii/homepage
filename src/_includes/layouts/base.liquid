<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ excerpt | default: 'hashiiiii - personal homepage' }}" />
  <link rel="icon" href="/public/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Nunito:wght@400;600;700;800&display=swap" />
  <link rel="stylesheet" href="/css/global.css" />
  {% if zennCss %}
  <!-- zenn-content.css is copied from node_modules via eleventy.config.js -->
  <link rel="stylesheet" href="/css/zenn-content.css" />
  <link rel="stylesheet" href="/css/zenn-overrides.css" />
  <script src="https://embed.zenn.studio/js/listen-embed-event.js"></script>
  {% endif %}
  <link rel="stylesheet" href="/css/pages.css" />
  <title>{% if title %}{{ title }} | {% endif %}hashiiiii</title>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EW66F2QF0H"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EW66F2QF0H');
  </script>
</head>
<body>
  {% render "header.liquid", page: page %}
  <main>
    {{ content }}
  </main>
</body>
</html>
