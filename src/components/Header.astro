---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { path: '/blog', label: 'Blog' },
  { path: '/resume', label: 'Resume' },
];
---

<header>
  <nav>
    <a href="/" class="site-title">hashiiiii</a>
    <div class="nav-links">
      {navLinks.map(({ path, label }) => (
        <a
          href={path}
          class:list={[{ active: currentPath.startsWith(path) }]}
        >
          {label}
        </a>
      ))}
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    z-index: 50;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1rem;
  }

  .site-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-accent);
    letter-spacing: 0.5px;
  }

  .site-title:hover {
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-links a.active {
    color: var(--color-text);
    font-weight: 600;
  }
</style>
