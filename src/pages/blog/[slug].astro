---
import Base from '../../layouts/Base.astro';
import { getPostBySlug, loadLocalPosts } from '../../lib/blog';
import 'zenn-content-css';

export async function getStaticPaths() {
  const posts = (await loadLocalPosts()).filter((p) => p.published !== false);
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/blog');
}

function formatDetailDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<Base title={post.title}>
  <article>
    <a href="/blog" class="back-link">&larr; Blog</a>
    <header>
      <h1>{post.title}</h1>
      <div class="meta">
        <span>{formatDetailDate(post.date)}  &middot;  {post.readTime}</span>
      </div>
      {post.tags.length > 0 && (
        <div class="tags">
          {post.tags.map((tag) => (
            <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
      <div class="header-divider"></div>
    </header>
    <div class="znc" set:html={post.html} />
  </article>
</Base>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .back-link:hover {
    color: var(--color-link-hover);
  }

  h1 {
    font-size: 1.75rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.75rem;
    border-radius: 9999px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    transition: color 0.2s, border-color 0.2s;
  }

  .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .header-divider {
    border-bottom: 1px solid var(--color-border);
    margin-top: 1rem;
    margin-bottom: 2.5rem;
  }
</style>

<style is:global>
  /* Zenn content dark theme overrides */
  .znc {
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .znc h1,
  .znc h2,
  .znc h3,
  .znc h4,
  .znc h5,
  .znc h6 {
    color: var(--color-text);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .znc h1 {
    font-size: 2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .znc h2 {
    font-size: 1.5rem;
  }

  .znc h3 {
    font-size: 1.25rem;
  }

  .znc a {
    color: var(--color-link);
  }

  .znc a:hover {
    color: var(--color-link-hover);
  }

  .znc pre {
    background-color: var(--color-code-bg) !important;
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
  }

  .znc code {
    font-family: var(--font-mono);
  }

  .znc :not(pre) > code {
    background-color: var(--color-bg-secondary);
    color: var(--color-code-text);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .znc table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5rem 0;
  }

  .znc th,
  .znc td {
    border: 1px solid var(--color-border);
    padding: 0.75rem;
    text-align: left;
  }

  .znc th {
    background-color: var(--color-bg-secondary);
    color: var(--color-text);
    font-weight: 600;
  }

  .znc blockquote {
    border-left: 4px solid var(--color-text-muted);
    background-color: var(--color-bg-secondary);
    padding: 1rem;
    margin: 1.5rem 0;
    border-radius: 0.5rem;
  }

  .znc ul,
  .znc ol {
    margin: 1rem 0;
    padding-left: 2rem;
  }

  .znc li {
    margin: 0.5rem 0;
  }

  .znc hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .znc img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .znc p {
    margin: 1rem 0;
  }

  .znc .msg {
    padding: 1rem;
    margin: 1.5rem 0;
    border-radius: 0.5rem;
    border-left: 4px solid;
  }

  .znc .msg.msg-info {
    background-color: rgba(107, 184, 115, 0.1);
    border-left-color: var(--color-accent);
  }

  .znc .msg.msg-alert {
    background-color: rgba(247, 118, 142, 0.1);
    border-left-color: #f7768e;
  }

  .znc .msg.msg-warn {
    background-color: rgba(224, 175, 104, 0.1);
    border-left-color: #e0af68;
  }

  .znc details {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-bg-secondary);
  }

  .znc details summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
    user-select: none;
  }

  .znc details[open] summary {
    margin-bottom: 1rem;
  }

  .znc input[type='checkbox'] {
    margin-right: 0.5rem;
    accent-color: var(--color-accent);
  }

  .znc .code-block-filename-container {
    background-color: var(--color-bg-secondary);
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .znc .code-block-filename {
    font-family: var(--font-mono);
  }

  .znc .code-block-container pre {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    margin-top: 0;
  }

  .znc .footnotes {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .znc .footnotes-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    display: block;
  }

  .znc .footnotes-list {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .znc .footnote-ref a,
  .znc .footnote-backref {
    color: var(--color-link);
    text-decoration: none;
  }
</style>
