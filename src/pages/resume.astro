---
import Base from '@/layouts/Base.astro';

interface ExperienceEntry {
  title: string;
  company?: string;
  period?: string;
  current?: boolean;
  description: string[];
}

const experience: ExperienceEntry[] = [
  {
    title: 'バックエンドプラットフォーム開発',
    company: '株式会社ディー・エヌ・エー',
    period: '2025年1月 - 現在',
    current: true,
    description: [
      'モバイルゲーム向け共通基盤の運用・開発 (Ruby on Rails / C++)',
      'API 開発、DB 設計、レガシーコンポーネントの移行',
      'C++ SDK のプロトコル改修・ミドルウェア開発',
    ],
  },
  {
    title: '新規モバイルゲーム開発 — リードエンジニア',
    company: '株式会社ディー・エヌ・エー',
    period: '2024年5月 - 2024年12月',
    description: [
      'Unity (Android / iOS) 大規模タイトルのアーキテクト・技術選定',
      '複数の協業各社とのステークホルダー連携・役務調整',
      'Clean Architecture ベースのクライアント基盤設計・パフォーマンスチューニング',
    ],
  },
  {
    title: '新規サービス開発',
    company: '株式会社ディー・エヌ・エー',
    period: '2023年9月 - 2024年5月',
    description: [
      'Unity クライアント (Clean Architecture) + C++ ネイティブプラグイン開発',
      'Go + GCP マネージドサービスを用いたサーバー開発',
    ],
  },
  {
    title: 'PC / WebGL ゲーム開発 — リードエンジニア',
    company: '株式会社ディー・エヌ・エー',
    period: '2022年9月 - 2023年9月',
    description: [
      'マルチプラットフォーム (macOS / Windows / WebGL) 対応のクライアント設計・開発',
      'PlayFab + Azure Functions (C#) によるサーバー開発',
      'GitHub Actions での CI/CD・Steam デプロイパイプライン構築',
      'GDPR 対応や Steam デベロッパー登録など非エンジニア領域もカバー',
    ],
  },
  {
    title: 'WebGL ゲーム開発 — リードエンジニア',
    company: '株式会社ディー・エヌ・エー',
    period: '2022年3月 - 2022年8月',
    description: [
      'ライブゲーミングプラットフォーム (fingger) 向けカジュアルゲームの開発',
    ],
  },
  {
    title: '運用モバイルゲーム — リードエンジニア',
    company: '株式会社ディー・エヌ・エー',
    period: '2019年4月 - 2022年3月',
    description: [
      'エンジニア 10 名規模のチームマネジメント・開発計画策定',
      'Unity クライアント開発全般 (リアルタイム PvP、UI / Animation)',
      'Ruby on Rails によるサーバー開発 (GvG グルーピング、チャット API 等)',
      'Jenkins CI/CD 構築、Unity 大型アップデート対応',
    ],
  },
];

const freelance: ExperienceEntry[] = [
  {
    title: 'Web 3 モバイルゲーム開発',
    description: [
      'Unity (Android / iOS) クライアント開発 — アーキテクチャ設計補助・コードレビュー',
      'IAP、ガチャ等のシステム実装、AssetBundle ビルドパイプライン構築',
    ],
  },
];

const education = {
  degree: '理学修士（惑星大気科学専攻）',
  university: '岡山大学大学院自然科学研究科',
  period: '2017年 - 2019年',
};

const skills = [
  {
    category: 'プログラミング言語',
    tags: ['C#', 'Ruby', 'C++', 'Go', 'TypeScript'],
  },
  {
    category: 'フロントエンド・フレームワーク',
    tags: ['Unity', 'Clean Architecture', 'MVP / DDD', 'Addressable Asset System', 'IAP', 'WebGL', 'Photon', 'Steam', 'fingger', 'React Native', 'React', 'Expo', 'Flutter'],
  },
  {
    category: 'バックエンド・フレームワーク',
    tags: ['Ruby on Rails', 'MySQL', 'PostgreSQL', 'Memcached', 'Hono', 'Node.js', 'Layered Architecture', 'MVC'],
  },
  {
    category: 'クラウド・インフラ',
    tags: ['AWS', 'GCP'],
  },
  {
    category: 'DevOps',
    tags: ['GitHub Actions', 'Jenkins'],
  },
  {
    category: 'ロール',
    tags: ['テックリード', 'チームマネジメント（2 - 10 名）', 'アーキテクト'],
  },
];
---

<Base title="Resume">
  <h1>Resume</h1>

  <section>
    <h2>職歴</h2>
    <div class="timeline">
      {experience.map((entry) => (
        <div class="timeline-entry">
          <span class="period">{entry.period}</span>
          <div class="company">{entry.company}</div>
          <div class="role">{entry.title}</div>
          <div class="description-list">
            {entry.description.map((item) => (
              <div class="desc-item">
                <span class="desc-marker">▸</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="divider" />

  <section>
    <h2>個人</h2>
    <div class="timeline">
      {freelance.map((entry) => (
        <div class="timeline-entry">
          <div class="role">{entry.title}</div>
          <div class="description-list">
            {entry.description.map((item) => (
              <div class="desc-item">
                <span class="desc-marker">▸</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="divider" />

  <section>
    <h2>学歴</h2>
    <div class="timeline-entry">
      <div class="company">{education.degree}</div>
      <div class="role">{education.university}</div>
      <span class="period">{education.period}</span>
    </div>
  </section>

  <hr class="divider" />

  <section>
    <h2>技術スキル</h2>
    <div class="skills-grid">
      {skills.map((category) => (
        <div class="skill-category">
          <span class="skill-label">{category.category}</span>
          <div class="skill-tags">
            {category.tags.map((tag) => (
              <span class="skill-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  h1 {
    font-size: 1.75rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-entry {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .company {
    font-weight: 700;
    font-size: 1.0625rem;
    margin-top: 0.25rem;
  }

  .role {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: 0.125rem;
  }

  .description-list {
    margin-top: 0.75rem;
  }

  .desc-item {
    display: flex;
    align-items: flex-start;
    gap: 0.375rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .desc-marker {
    color: var(--color-accent);
    flex-shrink: 0;
  }


  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-category {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }
</style>
