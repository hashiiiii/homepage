---

<Base title="Resume">
  <h1>Resume</h1>

  <section>
    <h2>職歴</h2>
    <div class="timeline">
      {experience.map((entry) => (
        <div class="timeline-entry">
          <span class="period">{entry.period}</span>
          <div class="company">{entry.company}</div>
          <div class="role">{entry.title}</div>
          <div class="description-list">
            {entry.description.map((item) =>
              typeof item === 'string' ? (
                <div class="desc-item">
                  <span class="desc-marker">▸</span>
                  <span>{item}</span>
                </div>
              ) : (
                <div class="desc-group">
                  <div class="desc-item">
                    <span class="desc-marker">▸</span>
                    <span>{item.text}</span>
                  </div>
                  {item.items && (
                    <div class="desc-children">
                      {item.items.map((child) => (
                        <div class="desc-item sub">
                          <span class="desc-marker">▸</span>
                          <span>{typeof child === 'string' ? child : (child as {text: string}).text}</span>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              )
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="divider" />

  <section>
    <h2>個人</h2>
    <div class="timeline">
      {freelance.map((entry) => (
        <div class="timeline-entry">
          <div class="role">{entry.title}</div>
          <div class="description-list">
            {entry.description.map((item) =>
              typeof item === 'string' ? (
                <div class="desc-item">
                  <span class="desc-marker">▸</span>
                  <span>{item}</span>
                </div>
              ) : (
                <div class="desc-group">
                  <div class="desc-item">
                    <span class="desc-marker">▸</span>
                    <span>{item.text}</span>
                  </div>
                  {item.items && (
                    <div class="desc-children">
                      {item.items.map((child) => (
                        <div class="desc-item sub">
                          <span class="desc-marker">▸</span>
                          <span>{typeof child === 'string' ? child : (child as {text: string}).text}</span>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              )
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <hr class="divider" />

  <section>
    <h2>学歴</h2>
    <div class="timeline-entry">
      <div class="company">{education.degree}</div>
      <div class="role">{education.university}</div>
      <span class="period">{education.period}</span>
    </div>
  </section>

  <hr class="divider" />

  <section>
    <h2>技術スキル</h2>
    <div class="skills-grid">
      {skills.map((category) => (
        <div class="skill-category">
          <span class="skill-label">{category.category}</span>
          <div class="skill-tags">
            {category.tags.map((tag) => (
              <span class="skill-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  h1 {
    font-size: 1.75rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-entry {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .timeline-entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .period {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .company {
    font-weight: 700;
    font-size: 1.0625rem;
    margin-top: 0.25rem;
  }

  .role {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: 0.125rem;
  }

  .description-list {
    margin-top: 0.75rem;
  }

  .desc-item {
    display: flex;
    align-items: flex-start;
    gap: 0.375rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .desc-marker {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .desc-children {
    padding-left: 1.25rem;
  }

  .desc-item.sub {
    font-size: 0.8125rem;
  }

  .desc-group {
    margin-bottom: 0.25rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-category {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-label {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }
</style>
