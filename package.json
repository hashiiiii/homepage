{
  "name": "homepage",
  "version": "3.0.0",
  "description": "Personal homepage for hashiiiii.com",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun eleventy --serve",
    "build": "bunx --bun eleventy",
    "typecheck": "tsc",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bunx --bun vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "gray-matter": "^4.0.3",
    "rss-parser": "^3.13.0",
    "zenn-content-css": "^0.5.2",
    "zenn-markdown-html": "^0.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "1.3.14",
    "husky": "9.1.7",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
