{
  "name": "homepage",
  "version": "3.0.0",
  "description": "Personal homepage for hashiiiii.com",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun eleventy --serve",
    "build": "bunx --bun eleventy",
    "typecheck": "tsc",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bunx --bun vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "gray-matter": "^4.0.3",
    "rss-parser": "^3.13.0",
    "zenn-content-css": "^0.4.6",
    "zenn-markdown-html": "^0.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "husky": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
